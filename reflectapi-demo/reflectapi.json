                "name": "std::string::String"
              },
              "required": true
            },
            {
              "name": "_context_marker",
              "type": {
                "name": "std::marker::PhantomData",
                "arguments": [
                  {
                    "name": "C"
                  }
                ]
              },
              "required": true
            },
